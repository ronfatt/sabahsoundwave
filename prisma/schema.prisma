generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingType {
  NORMAL_LISTING
  LAUNCH_SUPPORT
}

enum DiscoverySource {
  MANUAL
  SUBMISSION
  PLAYLIST
  SEARCH
  CSV_IMPORT
  YOUTUBE_CHANNEL
  YOUTUBE_SEARCH
}

enum VerificationStatus {
  NEEDS_REVIEW
  AUTO_APPROVED
  VERIFIED
  REJECTED
}

enum CandidateStatus {
  NEW
  REVIEWED
  DISMISSED
}

enum District {
  KOTA_KINABALU
  PAPAR
  PENAMPANG
  TUARAN
  RANAU
  KUDAT
  SANDAKAN
  LAHAD_DATU
  TAWAU
  SEMPORNA
  KENINGAU
  BEAUFORT
  SIPITANG
  TAMBUNAN
  KOTA_BELUD
}

model Artist {
  id              String           @id @default(cuid())
  slug            String           @unique
  status          SubmissionStatus @default(PENDING)
  type            ListingType      @default(NORMAL_LISTING)
  spotifyArtistId String?          @unique
  discoverySource DiscoverySource  @default(MANUAL)
  verificationStatus VerificationStatus @default(NEEDS_REVIEW)
  sabahConfidence Int              @default(0)
  sourceTags      String?
  discoveredAt    DateTime?
  hasSongReleased Boolean          @default(false)
  uploadLinks     String?
  contactWhatsapp String
  name            String
  district        District
  genres          String
  bio             String
  aiSummary       String?
  submitTermsAcceptedAt DateTime?
  starterAgreementAcceptedAt DateTime?
  starterAgreementVersion String?
  spotifyFollowers Int?
  artistCardClickCount Int       @default(0)
  profileViewCount Int           @default(0)
  songSpotlightViewCount Int     @default(0)
  songListenClickCount Int       @default(0)
  topTrackUrl     String?
  topTrackName    String?
  latestReleaseName String?
  latestReleaseDate DateTime?
  latestReleaseUrl String?
  lastSpotifySyncedAt DateTime?
  spotifyUrl      String?
  appleMusicUrl   String?
  youtubeUrl      String?
  coverImageUrl   String?
  featured        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  dropEvents      DropEvent[]

  @@index([district])
  @@index([status])
  @@index([type])
  @@index([verificationStatus])
  @@index([discoverySource])
  @@index([sabahConfidence])
  @@index([profileViewCount])
  @@index([songListenClickCount])
}

model DropEvent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String
  artists     Artist[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model YoutubeSeedChannel {
  id           String   @id @default(cuid())
  channelId    String   @unique
  channelTitle String
  source       String   @default("AUTO")
  active       Boolean  @default(true)
  promoted     Boolean  @default(false)
  hitCount     Int      @default(0)
  discoveredAt DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, promoted])
  @@index([hitCount])
}

model YoutubeDiscoveryCandidate {
  id             String          @id @default(cuid())
  sourceType     DiscoverySource
  status         CandidateStatus @default(NEW)
  confidence     Int
  artistName     String
  normalizedName String
  channelId      String
  channelTitle   String
  videoId        String          @unique
  songTitle      String
  publishedAt    DateTime
  watchUrl       String
  thumbnailUrl   String?
  sourceTerm     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status, confidence])
  @@index([normalizedName])
  @@index([channelId])
}

model NewsItem {
  id          String   @id @default(cuid())
  title       String
  url         String   @unique
  source      String?
  publishedAt DateTime
  summary     String?
  region      String   @default("GLOBAL")
  clickCount  Int      @default(0)
  lastClickedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@index([region, publishedAt])
  @@index([clickCount, publishedAt])
}
